{
	"$schema": "http://json.schemastore.org/prettierrc",
	"plugins": [
		"prettier-plugin-astro",
		"prettier-plugin-packagejson",
		"prettier-plugin-sentences-per-line"
	],
	"overrides": [
		{
			"files": "*.astro",
			"options": {
				"parser": "astro"
			}
		},
		{
			"files": ".*rc",
			"options": { "parser": "json" }
		},
		{
			"files": ".nvmrc",
			"options": { "parser": "yaml" }
		}
	],
	"useTabs": true
}
